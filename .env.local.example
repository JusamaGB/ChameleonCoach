# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth (for Eliot's Sheets access)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Resend (invite emails)
RESEND_API_KEY=re_your-api-key

# Admin (used only for initial role seeding — RBAC via user_roles table after setup)
ADMIN_EMAIL=eliot@example.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Chameleon memory
CHAMELEON_MCP_API_KEY=replace-with-a-long-random-secret
CHAMELEON_MEMORY_BASE_URL=http://127.0.0.1:3000
CHAMELEON_AGENT_ID=MARKETING
CHAMELEON_AGENT_NAME=Chameleon Marketing
CHAMELEON_LAUNCH_DATE=2026-04-12
MARKETING_SECRET_ENCRYPTION_KEY=replace-with-a-long-random-secret
CHAMELEON_RUNNER_INTERVAL_MS=45000
CHAMELEON_REDDIT_AUTOSCAN=true
CHAMELEON_REDDIT_AUTOSCAN_MINUTES=45
CHAMELEON_REDDIT_SUBREDDITS=smallbusiness,entrepreneur,personaltraining,fitnessbusiness,marketing,sales,onlinecoaching
CHAMELEON_REDDIT_SEARCH_TERMS=google sheets coach,google sheets fitness coach,spreadsheet personal trainer,spreadsheet coaching business,client onboarding spreadsheet coach
CHAMELEON_BUDGET_MODE=true
CHAMELEON_OPENAI_MODEL_DISCOVERY=gpt-5-nano
CHAMELEON_OPENAI_MODEL_DRAFTING=gpt-5-mini
CHAMELEON_OPENAI_MODEL_REVISION=gpt-5-mini
CHAMELEON_MAX_DRAFT_VARIANTS=2
CHAMELEON_MAX_OUTPUT_TOKENS=500

# Local runner AI (used by migration flows; marketing BYOK is coach-scoped)
OPENAI_API_KEY=sk-your-openai-key
